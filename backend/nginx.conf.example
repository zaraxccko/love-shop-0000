# nginx-конфиг для VPS.
# Положить в /etc/nginx/sites-available/shop, симлинкнуть в sites-enabled, certbot --nginx -d your-domain.com

server {
    listen 80;
    server_name your-domain.com;

    # === Frontend (статика собранного Vite) ===
    root /var/www/shop;
    index index.html;

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # === API → Node бэкенд в Docker (порт 3000) ===
    location /api/ {
        proxy_pass http://127.0.0.1:3000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 15M;
    }

    # === Загрузки (фото-закладки) ===
    location /uploads/ {
        proxy_pass http://127.0.0.1:3000/uploads/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
